# Copy to .env.local for development. Set the same keys on Vercel (Production + Preview as needed).

# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: Supabase → Settings → API → service_role (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Canonical public URL (production: https://buildinc.app)
NEXT_PUBLIC_SITE_URL=

# Billing without a gateway (beta / invoiced): POST /api/billing/unlock-with-code with JSON { code, tier } — tier matches app plans starter | professional | enterprise (same as PAYMENT_PLAN_ID_*).
BILLING_UNLOCK_CODE=

# Payment gateway (credentials + subscription plan ids from your dashboard)
# PAYMENT_KEY_ID=
# PAYMENT_KEY_SECRET=
# PAYMENT_WEBHOOK_SECRET=
# Header name gateway uses for webhook HMAC signature (dashboard → Webhooks)
# PAYMENT_WEBHOOK_SIGNATURE_HEADER=
# PAYMENT_PLAN_ID_STARTER=
# PAYMENT_PLAN_ID_PROFESSIONAL=
# PAYMENT_PLAN_ID_ENTERPRISE=
